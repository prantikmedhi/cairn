<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="CairnStudio — Visual agent loop engineering IDE. Build, validate, and collaborate on AI agent loops in a code-editor style workspace.">
    <meta name="keywords" content="CairnStudio, agent loop IDE, visual loop editor, agent loop engineering, AI workflow editor, collaborative loop builder">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://prantikmedhi.github.io/cairn/studio">
    <meta property="og:type" content="website">
    <meta property="og:title" content="CairnStudio — Visual Agent Loop Engineering IDE">
    <meta property="og:description" content="Code-editor style workspace for building, validating, previewing, and collaborating on Cairn loops.">
    <meta property="og:url" content="https://prantikmedhi.github.io/cairn/studio">
    <meta property="og:site_name" content="Cairn">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="CairnStudio — Visual Agent Loop Engineering IDE">
    <meta name="twitter:description" content="Code-editor style workspace for building, validating, previewing, and collaborating on Cairn loops.">
    <title>{{ page_title }} — Visual Agent Loop Engineering IDE</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "CairnStudio",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "macOS, Linux, Windows",
      "description": "Visual agent loop engineering IDE for the Cairn DSL. Build, validate, preview, and collaborate on AI agent loops.",
      "url": "https://github.com/prantikmedhi/cairn",
      "version": "0.1.0",
      "author": {
        "@type": "Organization",
        "name": "Cairn Contributors"
      }
    }
    </script>
    <link rel="stylesheet" href="/public/studio.css">
  </head>
  <body data-theme="midnight">
    <a class="skip-link" href="#workspace">Skip to editor</a>
    <main class="ide" id="workspace">
      <aside class="activity-bar" aria-label="Primary navigation">
        <button class="brand-button" type="button" title="CairnStudio home" aria-label="CairnStudio home">
          <svg class="icon" viewBox="0 0 24 24">
            <path d="M12 3a9 9 0 1 0 8.6 11.7"></path>
            <path d="M14.8 3.7H21v6.2"></path>
            <path d="M21 3l-8 8"></path>
          </svg>
        </button>

        <div class="activity-stack" role="tablist" aria-label="Sidebar panels">
          <button class="activity-button active" type="button" data-sidebar="explorer" title="Explorer" aria-label="Explorer">
            <svg class="icon" viewBox="0 0 24 24">
              <path d="M4 5h7l2 2h7v12H4z"></path>
              <path d="M4 9h16"></path>
            </svg>
          </button>
          <button class="activity-button" type="button" data-sidebar="library" title="Library" aria-label="Library">
            <svg class="icon" viewBox="0 0 24 24">
              <path d="M5 4h4v16H5z"></path>
              <path d="M10 4h4v16h-4z"></path>
              <path d="M15 4h4v16h-4z"></path>
            </svg>
          </button>
          <button class="activity-button" type="button" data-sidebar="settings" title="Settings" aria-label="Settings">
            <svg class="icon" viewBox="0 0 24 24">
              <path d="m12 3 1.7 3.4 3.8.6-2.7 2.7.6 3.8-3.4-1.7-3.4 1.7.6-3.8L6.5 7l3.8-.6Z"></path>
              <circle cx="12" cy="12" r="2.8"></circle>
            </svg>
          </button>
        </div>

        <button class="activity-button" type="button" id="shareSessionButton" title="Copy share link" aria-label="Copy share link">
          <svg class="icon" viewBox="0 0 24 24">
            <path d="M8 12a4 4 0 0 1 4-4h4"></path>
            <path d="M16 12a4 4 0 0 1-4 4H8"></path>
            <path d="M9 15 5 19"></path>
            <path d="M15 9 19 5"></path>
          </svg>
        </button>
      </aside>

      <aside class="sidebar" aria-label="Navigation sidebar">
        <div class="brand">
          <span class="phase-chip">{{ phase_badge }}</span>
          <h1>{{ page_title }}</h1>
          <p class="panel-copy">Code-editor style workspace for visual loop authoring, YAML editing, live preview, and shared collaboration.</p>
          <span class="room-chip">{{ collaboration_status }}</span>
        </div>

        <section class="sidebar-panel active" data-panel="explorer">
          <div>
            <div class="section-label">Loop Explorer</div>
            <div class="panel-copy">Navigate loop metadata and states like a project tree.</div>
          </div>
          <div class="meta-stack">
            <div class="tree-item">
              <div class="tree-row"><strong>loop.crn</strong><span class="meta-chip" id="loopVersionChip">0.1.0</span></div>
              <div class="tree-meta" id="loopSummary">Visual starter loop</div>
            </div>
            <div class="tree-list" id="treeList">
              <div class="status-card">No states loaded yet.</div>
            </div>
          </div>
          <div class="sidebar-footer meta-stack">
            <div>
              <div class="section-label">Session</div>
              <div class="status-copy"><code id="sessionLabel">{{ default_session_id }}</code></div>
            </div>
            <input id="shareSession" aria-label="Share session link" readonly>
          </div>
        </section>

        <section class="sidebar-panel" data-panel="library">
          <div>
            <div class="section-label">State Library</div>
            <div class="panel-copy">Insert building blocks, then arrange flow visually or refine in YAML.</div>
          </div>
          <div class="tool-list" role="list" aria-label="State palette">
            <button class="tool-card palette-card" type="button" draggable="true" data-kind="state" data-handler="core.collect">
              <div class="tool-row">
                <strong>Collect</strong>
                <span class="meta-chip">output</span>
              </div>
              <div class="helper-copy">Capture and forward structured values.</div>
            </button>
            <button class="tool-card palette-card" type="button" draggable="true" data-kind="state" data-handler="core.template">
              <div class="tool-row">
                <strong>Template</strong>
                <span class="meta-chip">transform</span>
              </div>
              <div class="helper-copy">Compose prompts and derived values from context.</div>
            </button>
            <button class="tool-card palette-card" type="button" draggable="true" data-kind="state" data-handler="core.condition">
              <div class="tool-row">
                <strong>Condition</strong>
                <span class="meta-chip">branch</span>
              </div>
              <div class="helper-copy">Drive branching decisions using expressions.</div>
            </button>
            <button class="tool-card palette-card" type="button" draggable="true" data-kind="subloop" data-handler="">
              <div class="tool-row">
                <strong>Sub-loop</strong>
                <span class="meta-chip">compose</span>
              </div>
              <div class="helper-copy">Reference imported loops as reusable stages.</div>
            </button>
          </div>
          <div class="sidebar-footer meta-stack">
            <label class="ghost-button" for="uploadYaml">Import .crn</label>
            <input hidden id="uploadYaml" type="file" accept=".crn,.cairn,.yaml,.yml">
            <button class="ghost-button" type="button" id="downloadYaml">Export .crn</button>
          </div>
        </section>

        <section class="sidebar-panel" data-panel="settings">
          <div>
            <div class="section-label">Workspace Settings</div>
            <div class="panel-copy">Tune theme, sync behavior, and default preview target.</div>
          </div>
          <div class="setting-stack">
            <div class="setting-card">
              <label class="label" for="themeSelect">Theme</label>
              <select id="themeSelect" aria-label="Theme">
                <option value="midnight">Midnight</option>
                <option value="aurora">Aurora</option>
                <option value="paper">Paper</option>
              </select>
            </div>
            <div class="setting-card">
              <label class="label" for="targetSelect">Default Preview Target</label>
              <select id="targetSelect" aria-label="Execution target">
                {% for target in available_targets %}
                <option value="{{ target }}">{{ target }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="setting-card">
              <label class="label" for="autoSyncToggle">Follow Remote Session</label>
              <select id="autoSyncToggle" aria-label="Remote sync mode">
                <option value="on">On</option>
                <option value="off">Off</option>
              </select>
            </div>
          </div>
        </section>
      </aside>

      <section class="editor-shell">
        <header class="editor-topbar">
          <div class="editor-title-group">
            <div class="breadcrumbs">
              <span>CairnStudio</span>
              <span>/</span>
              <span>sessions</span>
              <span>/</span>
              <code id="breadcrumbSession">{{ default_session_id }}</code>
            </div>
            <h2 class="editor-title">Loop Workspace</h2>
          </div>
          <div class="editor-toolbar">
            <div class="toolbar-group">
              <button class="action-button" type="button" id="syncFromYaml">
                <svg class="icon" viewBox="0 0 24 24"><path d="M21 12a9 9 0 0 1-15.5 6.2"></path><path d="M3 12A9 9 0 0 1 18.5 5.8"></path><path d="M3 16v-4h4"></path><path d="M21 8v4h-4"></path></svg>
                Sync from YAML
              </button>
              <button class="action-button primary" type="button" id="validateYaml">
                <svg class="icon" viewBox="0 0 24 24"><path d="m5 12 4 4L19 6"></path></svg>
                Validate
              </button>
              <button class="action-button" type="button" id="previewLoop">
                <svg class="icon" viewBox="0 0 24 24"><path d="m8 5 11 7-11 7z"></path></svg>
                Preview
              </button>
            </div>
          </div>
        </header>

        <div class="tab-row" role="tablist" aria-label="Editor views">
          <button class="tab-button active" type="button" data-view="graph">Graph</button>
          <button class="tab-button" type="button" data-view="yaml">YAML</button>
          <button class="tab-button" type="button" data-view="preview">Preview</button>
        </div>

        <div class="editor-content">
          <section class="editor-view active" data-view-panel="graph">
            <div class="graph-layout">
              <div class="canvas-wrap">
                <div class="canvas-header">
                  <div>
                    <div class="section-label">Canvas</div>
                    <div class="helper-copy">Drag from library, click nodes from explorer, and reposition flow.</div>
                  </div>
                  <span class="meta-chip" id="selectedNodeChip">No selection</span>
                </div>
                <div class="canvas empty" id="canvas" aria-label="Loop canvas"></div>
              </div>
              <aside class="graph-sidebar">
                <div class="mini-panel">
                  <h3>Loop metadata</h3>
                  <div class="helper-copy" id="loopMetaSummary">Starter loop ready for editing.</div>
                </div>
                <div class="mini-panel">
                  <h3>Navigation hints</h3>
                  <div class="helper-copy">Use Explorer for structure, Graph for layout, YAML for exact schema, Preview for runtime trace.</div>
                </div>
              </aside>
            </div>
          </section>

          <section class="editor-view" data-view-panel="yaml">
            <textarea id="yamlEditor" aria-label="Loop YAML">{{ starter_yaml }}</textarea>
          </section>

          <section class="editor-view" data-view-panel="preview">
            <div class="preview-layout">
              <aside class="preview-sidebar">
                <div class="preview-header">
                  <div>
                    <div class="section-label">Inputs</div>
                    <div class="helper-copy">Provide JSON inputs for execution preview.</div>
                  </div>
                </div>
                <div class="input-stack" style="margin-top: 14px;">
                  <label class="label" for="inputJson">Preview Inputs JSON</label>
                  <textarea id="inputJson" aria-label="Preview inputs JSON">{"prompt":"hello"}</textarea>
                </div>
              </aside>
              <div class="preview-panel">
                <div class="preview-header">
                  <div>
                    <div class="section-label">Trace Replay</div>
                    <div class="helper-copy">Preview state execution and replay path order.</div>
                  </div>
                  <span class="status-pill" id="previewTargetPill">langchain</span>
                </div>
                <div class="trace-list" id="traceList"></div>
              </div>
            </div>
          </section>
        </div>

        <footer class="status-bar">
          <div class="status-row">
            <div><strong>Status:</strong> <span id="statusBarMessage">Workspace ready.</span></div>
            <div class="status-copy">
              <span>Theme <code id="statusTheme">midnight</code></span>
              <span> · View <code id="statusView">graph</code></span>
              <span> · Session <code id="statusSession">{{ default_session_id }}</code></span>
            </div>
          </div>
        </footer>
      </section>

      <aside class="utility-dock" aria-label="Inspector and collaboration">
        <section class="dock-panel">
          <div class="title-row">
            <div>
              <div class="section-label">Inspector</div>
              <h3 class="dock-title">Node details</h3>
            </div>
            <span class="meta-chip" id="inspectorNodeType">state</span>
          </div>
          <div id="validationStatus" class="status-card">Workspace ready.</div>
          <div class="inspector-form" id="inspectorFields">
            <div class="status-card">No node selected yet.</div>
          </div>
        </section>

        <section class="dock-panel">
          <div class="title-row">
            <div>
              <div class="section-label">Collaboration</div>
              <h3 class="dock-title">Presence and activity</h3>
            </div>
            <span class="meta-chip" id="presenceCountChip">0 active</span>
          </div>
          <div class="collab-form">
            <label class="label" for="collaboratorName">Display Name</label>
            <input id="collaboratorName" aria-label="Collaborator name" placeholder="Your name">
            <label class="label" for="commentInput">Comment</label>
            <textarea id="commentInput" aria-label="Comment message" placeholder="Leave implementation notes, review comments, or handoff context"></textarea>
            <button class="send-button" type="button" id="sendComment">
              <svg class="icon" viewBox="0 0 24 24"><path d="M22 2 11 13"></path><path d="M22 2 15 22l-4-9-9-4z"></path></svg>
              Send comment
            </button>
          </div>
          <div>
            <div class="section-label">Presence</div>
            <div class="presence-list" id="presenceList">
              <div class="status-card">No collaborators active yet.</div>
            </div>
          </div>
          <div>
            <div class="section-label">Activity feed</div>
            <div class="activity-list" id="activityList">
              <div class="status-card">Waiting for collaboration events.</div>
            </div>
          </div>
        </section>
      </aside>
    </main>

    <script>
      window.CAIRN_CONFIG = {
        defaultSessionId: "{{ default_session_id }}"
      };
    </script>
    <script src="/public/studio.js"></script>
  </body>
</html>
