<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="CairnStudio — Visual agent loop engineering IDE. Build, validate, and collaborate on AI agent loops in a code-editor style workspace.">
    <meta name="keywords" content="CairnStudio, agent loop IDE, visual loop editor, agent loop engineering, AI workflow editor, collaborative loop builder">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://prantikmedhi.github.io/cairn/studio">
    <meta property="og:type" content="website">
    <meta property="og:title" content="CairnStudio — Visual Agent Loop Engineering IDE">
    <meta property="og:description" content="Code-editor style workspace for building, validating, previewing, and collaborating on Cairn loops.">
    <meta property="og:url" content="https://prantikmedhi.github.io/cairn/studio">
    <meta property="og:site_name" content="Cairn">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="CairnStudio — Visual Agent Loop Engineering IDE">
    <meta name="twitter:description" content="Code-editor style workspace for building, validating, previewing, and collaborating on Cairn loops.">
    <title>{{ page_title }} — Visual Agent Loop Engineering IDE</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "CairnStudio",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "macOS, Linux, Windows",
      "description": "Visual agent loop engineering IDE for the Cairn DSL. Build, validate, preview, and collaborate on AI agent loops.",
      "url": "https://github.com/prantikmedhi/cairn",
      "version": "0.1.0",
      "author": {
        "@type": "Organization",
        "name": "Cairn Contributors"
      }
    }
    </script>
    <link rel="stylesheet" href="/public/studio.css">
  </head>
  <body data-theme="midnight">
    <div id="app-root"></div>

    <script>
      window.CAIRN_CONFIG = {
        defaultSessionId: "{{ default_session_id }}"
      };
    </script>
    <script src="/public/studio-app.js"></script>
    <script>
      window.CairnStudioApp.mount(document.getElementById("app-root"), {
        pageTitle: {{ page_title | tojson }},
        phaseBadge: {{ phase_badge | tojson }},
        collaborationStatus: {{ collaboration_status | tojson }},
        defaultSessionId: {{ default_session_id | tojson }},
        availableTargets: {{ available_targets | tojson }},
        starterYaml: {{ starter_yaml | tojson }}
      });
    </script>
    <script src="/public/studio.js"></script>
  </body>
</html>
