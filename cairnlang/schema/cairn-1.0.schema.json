{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cairn.dev/schema/cairn-1.0.schema.json",
  "title": "Cairn 1.0 Loop",
  "type": "object",
  "required": ["cairn", "loop"],
  "properties": {
    "cairn": {
      "anyOf": [
        { "type": "string", "const": "1.0" },
        { "type": "number", "const": 1.0 }
      ]
    },
    "loop": {
      "type": "object",
      "required": ["id", "name", "version", "states"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "imports": {
          "type": "array",
          "items": { "$ref": "#/$defs/import" }
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "required": { "type": "boolean" },
              "description": { "type": "string" },
              "default": {},
              "properties": { "type": "object" }
            },
            "additionalProperties": true
          }
        },
        "outputs": {
          "type": "object",
          "additionalProperties": true
        },
        "budget": {
          "type": "object",
          "properties": {
            "max_cost_usd": { "type": "number", "minimum": 0 },
            "max_duration": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?(ms|s|m|h)$" },
            "max_iterations": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        },
        "states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string" },
              "handler": { "type": "string", "minLength": 1 },
              "loop": { "type": "string", "minLength": 1 },
              "condition": { "type": ["string", "boolean", "number"] },
              "timeout": { "type": "string" },
              "inputs": {
                "type": "object",
                "additionalProperties": true
              },
              "transitions": {
                "type": "array",
                "items": { "$ref": "#/$defs/transition" }
              }
            },
            "additionalProperties": true
          }
        },
        "transitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/transition" }
        },
        "on_error": { "$ref": "#/$defs/hook" },
        "on_budget_exceeded": { "$ref": "#/$defs/hook" }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "transition": {
      "type": "object",
      "required": ["to"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string", "minLength": 1 },
        "condition": { "type": "string" },
        "if": { "type": "string" }
      },
      "additionalProperties": true
    },
    "import": {
      "type": "object",
      "required": ["name", "source"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "hook": {
      "type": "object",
      "required": ["handler"],
      "properties": {
        "handler": { "type": "string", "minLength": 1 },
        "inputs": {
          "type": "object",
          "additionalProperties": true
        },
        "message": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
